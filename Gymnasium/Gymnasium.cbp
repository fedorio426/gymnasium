<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Gymnasium" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Gymnasium" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Gymnasium.exe" prefix_auto="1" extension_auto="0" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
					<Add option="-static-libstdc++" />
					<Add option="-static-libgcc" />
					<Add option="-static" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add option="-fexceptions" />
			<Add directory="C:/development/nana/include" />
			<Add directory="C:/development/nana/extrlib/jpeg-9b/nana_extrlib" />
			<Add directory="C:/development/nana/extrlib/png/nana_extrlib" />
			<Add directory="C:/development/nana/extrlib/zlib/nana_extrlib" />
			<Add directory="C:/development/SQLite" />
			<Add directory="sqlite3pp" />
		</Compiler>
		<Linker>
			<Add library="nana" />
			<Add library="libjpeg.a" />
			<Add library="libpng.a" />
			<Add library="libzlib.a" />
			<Add library="libsqlite3.a" />
			<Add library="comdlg32" />
			<Add library="gdi32" />
			<Add directory="C:/development/nana/lib" />
			<Add directory="C:/development/nana/extrlib/jpeg-9b" />
			<Add directory="C:/development/nana/extrlib/png" />
			<Add directory="C:/development/nana/extrlib/zlib" />
			<Add directory="C:/development/SQLite" />
		</Linker>
		<Unit filename="Database.cpp" />
		<Unit filename="Database.h" />
		<Unit filename="Gymnasium.cpp" />
		<Unit filename="logger.h" />
		<Unit filename="project.ico" />
		<Unit filename="project.rc">
			<Option compilerVar="WINDRES" />
		</Unit>
		<Unit filename="search.hpp" />
		<Unit filename="sqlite3pp/sqlite3pp.h" />
		<Unit filename="sqlite3pp/sqlite3pp.ipp" />
		<Unit filename="sqlite3pp/sqlite3ppext.h" />
		<Unit filename="sqlite3pp/sqlite3ppext.ipp" />
		<Unit filename="utils.cpp" />
		<Unit filename="utils.h" />
		<Extensions />
	</Project>
</CodeBlocks_project_file>
